<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.techstar.pvms.backend.module.forecast.repository.ForecastModelMapper">

    <select id="findAll" resultType="cn.techstar.pvms.backend.module.forecast.repository.ForecastModelMapper$ModelRow">
        SELECT
            id,
            name,
            type,
            version,
            provider,
            description,
            status
        FROM fc_model
        ORDER BY type, id
    </select>

</mapper>
