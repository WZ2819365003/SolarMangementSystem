<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.techstar.pvms.backend.module.stationarchive.repository.StationArchiveInverterAlarmMapper">

    <select id="findByInverterId" resultType="cn.techstar.pvms.backend.module.stationarchive.repository.StationArchiveInverterAlarmMapper$InverterAlarmRow">
        SELECT id, inverter_id, event_time, type, level, description, status
        FROM sa_inverter_alarm
        WHERE inverter_id = #{inverterId}
        ORDER BY event_time DESC
    </select>

</mapper>
