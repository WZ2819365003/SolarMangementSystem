{
  "name": "hs-dtk-ui",
  "version": "0.1.29",
  "private": false,
  "main": "lib/index.js",
  "style": "lib/theme-chalk/index.css",
  "unpkg": "lib/index.js",
  "files": [
    "lib"
  ],
  "typings": "types/index.d.ts",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build:esm": "vue-cli-service build",
    "build:theme": "rimraf packages/theme-chalk/lib && gulp build --gulpfile packages/theme-chalk/gulpfile.js && cp-cli packages/theme-chalk/lib lib/theme-chalk && node build/fontPath.js",
    "build:utils": "babel src --out-dir lib --ignore src/fonts --presets=babel-preset-env,stage-2",
    "build:deploy": "cross-env BUILD_TYPE=deploy vue-cli-service build",
    "build": "npm run build:esm && npm run build:theme && npm run build:utils",
    "build:umd": "vue-cli-service build --target lib --name itmgui --dest lib/umd packages/index.js",
    "create": "node build/createComponent.js",
    "test:unit": "vue-cli-service test:unit",
    "lint": "vue-cli-service lint"
  },
